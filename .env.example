# Required: CoinGecko API key (Demo or Pro key)
COINGECKO_API_KEY=your_coingecko_key_here

# Required in production for screenshot service:
# public base URL where this app is reachable by external services
APP_BASE_URL=https://coins-tau-one.vercel.app

# Optional client-side public URL helper
NEXT_PUBLIC_APP_URL=https://coins-tau-one.vercel.app

# Required for NextAuth session/JWT signing
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_long_random_secret

# Local development URL
NEXTAUTH_URL=http://localhost:3000
# In production (Vercel), set NEXTAUTH_URL to your public domain, e.g.
# NEXTAUTH_URL=https://coins-tau-one.vercel.app

# X App keys (with Read and Write permissions)
AUTH_TWITTER_ID=O8VJOwI5gA1oLlDKYfw0iiXy0
AUTH_TWITTER_SECRET=gyX0sgTIq4OlQRH8yKieRbYjgsDAuyV2BBipgxjBfd0B3BnQvU

