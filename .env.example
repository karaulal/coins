# Required: CoinGecko API key (Demo or Pro key)
COINGECKO_API_KEY=your_coingecko_key_here

# Required in production for screenshot service:
# public base URL where this app is reachable by external services
APP_BASE_URL=https://coins-tau-one.vercel.app

# Optional client-side public URL helper
NEXT_PUBLIC_APP_URL=https://coins-tau-one.vercel.app

# Required for server-side Firebase Admin writes (single-line JSON)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"trendingcoins007","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
